# ==============================
# FoodRescue Intelligence — Root .gitignore
# Defense-in-depth: prevents accidental commits of secrets
# ==============================

# ── Environment & Secrets ──
.env
.env.*
!.env.example
*.key
*.pem
*.crt

# ── Python ──
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
*.egg

# ── Virtual Environments ──
.venv/
venv/
env/
ENV/

# ── Database ──
*.sqlite3
db.sqlite3

# ── Node.js ──
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── Build Outputs ──
dist/
build/
*.local

# ── Media / Uploads ──
media/

# ── IDE & Editor ──
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── OS Files ──
.DS_Store
Thumbs.db
Desktop.ini
*.tmp
*.bak

# ── Logs ──
*.log
*.pid

# ── Coverage & Testing ──
htmlcov/
.coverage
.coverage.*
.pytest_cache/
.tox/
